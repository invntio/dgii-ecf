{% set fiscal = get_ecf_print_data(doc.name) %}
{% set billing_reference = get_billing_reference_print_data(doc.name) %}
<style>
  .ri { color: #374151; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; font-size: 10px; line-height: 1.3; margin: 0; padding: 0; }
  
  /* Header */
  .ri-header { display: table; width: 100%; margin-bottom: 8px; }
  .ri-issuer, .ri-document { display: table-cell; vertical-align: top; width: 50%; }
  .ri-document { text-align: right; }
  .ri-logo { max-height: 50px; max-width: 160px; margin-bottom: 4px; }
  .ri-company { color: #111827; font-size: 16px; font-weight: 700; margin-bottom: 3px; }
  .ri-issuer-details { color: #4b5563; line-height: 1.3; }
  
  .ri-document h1 { color: #2563eb; font-size: 16px; font-weight: 700; margin: 0 0 4px; }
  .ri-document-meta { color: #374151; line-height: 1.35; }
  
  .ri-header-line { border-bottom: 2px solid #2563eb; margin: 6px 0 12px; }

  /* Client Box */
  .ri-party { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 11px; line-height: 1.4; padding: 10px 14px; margin-bottom: 12px; }
  .ri-party-row { margin-bottom: 2px; }
  .ri-party-row:last-child { margin-bottom: 0; }

  /* Product Table */
  .ri-table { border-collapse: collapse; width: 100%; margin-bottom: 16px; }
  .ri-table thead { display: table-header-group; }
  .ri-table th { background: #f8fafc; border: 1px solid #e5e7eb; border-bottom: 2px solid #e5e7eb; color: #111827; font-weight: 700; padding: 8px 10px; text-align: center; font-size: 10px; }
  .ri-table td { border: 1px solid #e5e7eb; padding: 8px 10px; color: #374151; font-size: 10px; }
  .ri-table .number { text-align: right; white-space: nowrap; }
  .ri-table .center { text-align: center; }

  /* Summary Section (QR + Totals) */
  .ri-summary { display: table; width: 100%; page-break-inside: avoid; margin-top: 8px; }
  .ri-verification, .ri-totals { display: table-cell; vertical-align: top; }
  .ri-verification { width: 50%; }
  .ri-totals { width: 50%; padding-left: 15px; }

  /* QR Box */
  .ri-verification-box { display: inline-block; border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; text-align: center; background: #ffffff; }
  .ri-qr { height: 100px; width: 100px; display: block; margin: 0 auto 8px; }
  .ri-verification-meta { font-size: 9px; color: #6b7280; line-height: 1.4; }
  .ri-verification-meta div { margin-bottom: 2px; }

  /* Integrated Totals Table */
  .ri-totals-table { border-collapse: separate; border-spacing: 0; width: 100%; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; }
  .ri-totals-table td { padding: 8px 12px; font-size: 10px; border-bottom: 1px solid #e5e7eb; }
  .ri-totals-table tr:last-child td { border-bottom: none; }
  .ri-totals-table .label { text-align: right; font-weight: 600; color: #374151; background: #f8fafc; border-right: 1px solid #e5e7eb; width: 60%; }
  .ri-totals-table .val { text-align: right; color: #111827; background: #ffffff; width: 40%; font-weight: 500; }
  
  /* Highlighted Total Row */
  .ri-totals-table .total-row td { background: #2563eb; color: #ffffff; font-weight: 700; font-size: 11px; padding: 10px 12px; }
  .ri-totals-table .total-row .label { background: #2563eb; color: #ffffff; border-right: 1px solid #3b82f6; text-transform: uppercase; }
  .ri-totals-table .total-row .val { background: #2563eb; color: #ffffff; }

  /* Warnings & Notices */
  .ri-notice { background: #eff6ff; border: 1px solid #bfdbfe; border-left: 4px solid #2563eb; border-radius: 8px; color: #1e40af; margin: 10px 0; padding: 10px 12px; }
  .ri-warning { background: #fffbe6; border: 1px solid #ffe58f; border-left: 4px solid #f59e0b; border-radius: 8px; color: #92400e; margin: 10px 0; padding: 10px 12px; }
  .ri-danger { background: #fef2f2; border: 1px solid #fca5a5; border-left: 4px solid #ef4444; border-radius: 8px; color: #991b1b; margin: 10px 0; padding: 10px 12px; }
  .ri-message-title { display: block; font-size: 10px; font-weight: 700; margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

  .ri-footer { color: #9ca3af; font-size: 8.5px; margin-top: 20px; text-align: center; }
  .ri-reference { font-weight: 700; margin-top: 2px; }

  @media print {
    .ri-summary, .ri-table tr { break-inside: avoid; page-break-inside: avoid; }
  }
</style>

<div class="ri">
  <div class="ri-header">
    <div class="ri-issuer">
      {% if fiscal and fiscal.company_logo %}<img class="ri-logo" src="{{ fiscal.company_logo }}">{% endif %}
      <div class="ri-company">{{ fiscal.issuer_name if fiscal else doc.company }}</div>
      <div class="ri-issuer-details">
        {% if fiscal and fiscal.issuer_rnc %}<div><strong>{{ _("RNC") }}:</strong> {{ fiscal.issuer_rnc }}</div>{% endif %}
        {% if fiscal and fiscal.issuer_address %}<div>{{ fiscal.issuer_address }}</div>{% endif %}
        <div><strong>{{ _("Fecha Emisión") }}:</strong> {{ fiscal.issue_date if fiscal else frappe.format(doc.posting_date, {"fieldtype": "Date"}) }}</div>
      </div>
    </div>
    <div class="ri-document">
      <h1>{{ _(fiscal.title) if fiscal else _("Factura de Consumo Electrónica") }}</h1>
      <div class="ri-document-meta">
        {% if fiscal %}
          <div><strong>{{ _("e-NCF") }}:</strong> {{ fiscal.encf }}</div>
          {% if fiscal.status %}<div><strong>{{ _("Estado e-CF") }}:</strong> {{ fiscal.status }}</div>{% endif %}
          {% if fiscal.sequence_expiry %}<div><strong>{{ _("Fecha de Vencimiento") }}:</strong> {{ fiscal.sequence_expiry }}</div>{% endif %}
          {% if fiscal.modified_encf %}<div class="ri-reference"><strong>{{ _("NCF Modificado") }}:</strong> {{ fiscal.modified_encf }}</div>{% endif %}
          {% if fiscal.correction_reason %}<div>{{ fiscal.correction_reason }}</div>{% endif %}
        {% else %}
          <div>{{ doc.name }}</div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="ri-header-line"></div>

  <div class="ri-party">
    <div class="ri-party-row"><strong>{{ _("Razón Social Cliente") }}:</strong> {{ fiscal.buyer_name if fiscal else (doc.customer_name or doc.customer) }}</div>
    {% if fiscal and fiscal.buyer_rnc and fiscal.buyer_rnc != "00000000000" %}<div class="ri-party-row"><strong>{{ _("RNC Cliente") }}:</strong> {{ fiscal.buyer_rnc }}</div>{% endif %}
    {% if billing_reference %}<div class="ri-party-row"><strong>{{ _(billing_reference.label) }}:</strong> {{ billing_reference.value }}</div>{% endif %}
  </div>

  {% set pending_statuses = ("Pending", "SUBMITTING", "UNCONFIRMED", "RECIBIDO", "PROCESANDO") %}
  {% set temporary_validation_error = fiscal and fiscal.operator_presentation and fiscal.operator_presentation.kind == "temporary_validation_error" %}
  {% set invalid_fiscal = fiscal and (fiscal.status == "Rechazado" or (fiscal.status == "ERROR" and fiscal.error_kind == "Validation")) %}
  {% if not fiscal and doc.docstatus == 0 %}
    <div class="ri-notice">
      <strong class="ri-message-title">{{ _("Vista previa de borrador") }}</strong>
      {{ _("El e-CF y sus identificadores fiscales se generarán al enviar esta factura.") }}
    </div>
  {% elif not fiscal %}
    <div class="ri-danger">
      <strong class="ri-message-title">{{ _("Comprobante fiscal electrónico faltante") }}</strong>
      {{ _("Esta factura enviada no tiene e-CF y no debe entregarse como comprobante fiscal.") }}
    </div>
  {% elif temporary_validation_error %}
    <div class="ri-warning">
      <strong class="ri-message-title">{{ _(fiscal.operator_presentation.title) }}</strong>
      {{ _(fiscal.operator_presentation.message) }}
      {% if fiscal.operator_presentation.provider_messages %}
        <div><strong>{{ _("Respuesta DGII") }}:</strong> {{ fiscal.operator_presentation.provider_messages[0] }}</div>
      {% endif %}
    </div>
  {% elif invalid_fiscal %}
    <div class="ri-danger">
      <strong class="ri-message-title">{{ _("Comprobante fiscal electrónico rechazado") }}</strong>
      {{ _("Este e-CF fue rechazado o falló la validación fiscal y no es válido para fines fiscales.") }}
    </div>
  {% elif fiscal.status in pending_statuses or fiscal.status == "ERROR" %}
    <div class="ri-warning">
      <strong class="ri-message-title">{{ _("Comprobante fiscal electrónico pendiente") }}</strong>
      {{ _("El e-CF fue generado, pero su transmisión o validación en la DGII está pendiente.") }}
    </div>
  {% endif %}

  <table class="ri-table">
    <thead>
      <tr>
        <th>{{ _("Cantidad") }}</th>
        <th>{{ _("Descripción") }}</th>
        <th>{{ _("Unidad de Medida") }}</th>
        <th>{{ _("Precio") }}</th>
        <th>{{ _("ITBIS") }}</th>
        <th>{{ _("Valor") }}</th>
      </tr>
    </thead>
    <tbody>
      {% if fiscal %}
        {% for item in fiscal.lines %}
        <tr>
          <td class="center">{{ (item.quantity | int) if (item.quantity % 1 == 0) else item.quantity }}</td>
          <td>{{ item.description }}</td>
          <td class="center">{{ item.uom }}</td>
          <td class="number">{{ frappe.format(item.rate, {"fieldtype": "Currency", "options": fiscal.currency}) }}</td>
          <td class="number">{{ frappe.format(item.tax, {"fieldtype": "Currency", "options": fiscal.currency}) }}</td>
          <td class="number">{{ frappe.format(item.amount, {"fieldtype": "Currency", "options": fiscal.currency}) }}</td>
        </tr>
        {% endfor %}
      {% else %}
        {% for item in doc.items %}
        <tr>
          <td class="center">{{ (item.qty | int) if (item.qty % 1 == 0) else item.qty }}</td>
          <td>{{ item.item_name or item.item_code }}</td>
          <td class="center">{{ item.uom }}</td>
          <td class="number">{{ frappe.format(item.net_rate, {"fieldtype": "Currency", "options": doc.currency}) }}</td>
          <td class="number">—</td>
          <td class="number">{{ frappe.format(item.net_amount, {"fieldtype": "Currency", "options": doc.currency}) }}</td>
        </tr>
        {% endfor %}
      {% endif %}
    </tbody>
  </table>

  <div class="ri-summary">
    <div class="ri-verification">
      {% if fiscal and fiscal.qr_url %}
        <div class="ri-verification-box">
          <img class="ri-qr" src="{{ qr_svg_data_uri(fiscal.qr_url) }}" alt="{{ _("Código QR de verificación DGII") }}">
          <div class="ri-verification-meta">
            <div><strong>{{ _("Código de Seguridad") }}:</strong> {{ fiscal.security_code }}</div>
            <div><strong>{{ _("Fecha Firma") }}:</strong> {{ fiscal.signed_date }}</div>
          </div>
        </div>
      {% endif %}
    </div>
    <div class="ri-totals">
      {% set currency = fiscal.currency if fiscal else doc.currency %}
      {% set taxable = fiscal.taxable_total if fiscal else doc.net_total %}
      {% set taxes = fiscal.tax_total if fiscal else doc.total_taxes_and_charges %}
      {% set total = fiscal.grand_total if fiscal else doc.grand_total %}
      <table class="ri-totals-table">
        <tr>
          <td class="label">{{ _("Subtotal Gravado") }}:</td>
          <td class="val">{{ frappe.format(taxable, {"fieldtype": "Currency", "options": currency}) }}</td>
        </tr>
        <tr style="display: {{ 'table-row' if (fiscal and fiscal.exempt_total) else 'none' }};">
          <td class="label">{{ _("Monto Exento") }}:</td>
          <td class="val">{{ frappe.format(fiscal.exempt_total if fiscal else 0, {"fieldtype": "Currency", "options": currency}) }}</td>
        </tr>
        <tr>
          <td class="label">{{ _("Total ITBIS") }}:</td>
          <td class="val">{{ frappe.format(taxes, {"fieldtype": "Currency", "options": currency}) }}</td>
        </tr>
        <tr class="total-row">
          <td class="label">{{ _("TOTAL A PAGAR") }}:</td>
          <td class="val"><strong>{{ frappe.format(total, {"fieldtype": "Currency", "options": currency}) }}</strong></td>
        </tr>
      </table>
    </div>
  </div>

  {% if not fiscal and doc.docstatus == 0 %}
    <div class="ri-footer">{{ _("Borrador — no es un documento fiscal.") }}</div>
  {% elif not fiscal %}
    <div class="ri-footer">{{ _("Este documento no es una representación impresa de e-CF y no es válido para fines fiscales.") }}</div>
  {% elif invalid_fiscal or temporary_validation_error %}
    <div class="ri-footer">{{ _("Este documento no es válido para fines fiscales.") }}</div>
  {% endif %}
</div>
